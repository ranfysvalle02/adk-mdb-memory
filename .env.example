# ---------------------------------------------------------------------------
# adk-mongodb-memory - example environment configuration
# Copy this file to `.env` and fill in your values:  cp .env.example .env
# `.env` is gitignored; never commit real secrets.
# ---------------------------------------------------------------------------

# === Voyage AI embeddings (REQUIRED) =======================================
# Every example needs real Voyage embeddings - there is no offline fallback.
# Get a key from the Voyage dashboard: https://dash.voyageai.com/api-keys
# (MongoDB Atlas customers can instead create one in the Atlas UI under
#  "AI Models"; the voyageai client auto-routes either key.)
VOYAGE_API_KEY="pa-..."

# Embedding model. Default: voyage-3.5 (1024-dim, multilingual, retrieval-tuned).
# Other options: voyage-4-large (best quality), voyage-4 (balanced),
# voyage-4-lite (cheapest/fastest), voyage-code-3 (code). All support
# output dimensions 256 / 512 / 1024 / 2048.
EMBEDDING_MODEL="voyage-3.5"

# Output dimensionality. MUST match EMBEDDING_MODEL's output and the Atlas
# Vector Search index. Default 1024 (the voyage-3.5 / voyage-4 family default).
EMBEDDING_DIMENSIONS="1024"

# === MongoDB (OPTIONAL - defaults to local Atlas) ==========================
# If MONGODB_URI is unset, the examples target a local MongoDB Atlas container at
#   mongodb://localhost:27017/?directConnection=true
# Start one with the docker one-liner (it bundles mongod + mongot, so
# $vectorSearch works locally):
#   docker run -d -p 27017:27017 mongodb/mongodb-atlas-local
#
# For CLOUD Atlas, set MONGODB_URI to your SRV string. Cloud Vector Search needs
# a tier that supports it (M10+ dedicated, or a Flex cluster; free M0 does NOT).
# Find it in Atlas: Database > Connect > Drivers.
# MONGODB_URI="mongodb+srv://USERNAME:PASSWORD@your-cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority"

# Database / collection the memory documents live in (created on first write).
MONGODB_DB_NAME="adk_memory"
MONGODB_COLLECTION_NAME="agent_memories"

# Name of the Atlas Vector Search index (created programmatically by setup_indexes()).
MONGODB_VECTOR_INDEX_NAME="vector_index"

# === Gemini / Google AI (only example 02 needs this) =======================
# Example 02 uses an LlmAgent chat model. Get a key from Google AI Studio:
# https://aistudio.google.com/apikey  (either variable name works).
GOOGLE_API_KEY=""
# GEMINI_API_KEY=""

# Chat model used by example 02's agents (any ADK-supported model works).
GEMINI_MODEL="gemini-2.5-flash"

# === Optional behaviour =====================================================
# Compliance auto-purge: delete memory documents this many seconds after their
# last update (creates a TTL index). Leave unset/empty to disable.
# Example: 2592000 = 30 days.
# MEMORY_TTL_SECONDS=""

# Set to "true" to enable the trivial transcript distiller (memory compression
# hook). Off by default. Distillation compresses the text before embedding; it
# does NOT change that embeddings are real Voyage vectors.
# MEMORY_DISTILL="false"

# === Demo identity (tenant isolation keys) ==================================
# app_name + user_id scope every read/write. Searches never cross tenants.
APP_NAME="memory_demo_app"
USER_ID="demo_user"
